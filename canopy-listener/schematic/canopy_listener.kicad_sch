  ;; =============================================
  ;; Net connections (schematic wiring)
  ;; =============================================

  ;; I2C Bus — BME280 + SSD1306
  ;; U1.GP18 → U7.SDA, U8.SDA, R3 pullup
  ;; U1.GP19 → U7.SCL, U8.SCL, R4 pullup
  ;; R3 (4.7k) from VDD to SDA line
  ;; R4 (4.7k) from VDD to SCL line

  ;; I2S Audio — dual MEMS microphones
  ;; U1.GP8 (PIO SM0) → U3.SCLK, U4.SCLK  (I2S BCLK)
  ;; U1.GP9 (PIO SM0) → U3.WS, U4.WS       (I2S LRCLK)
  ;; U3.SD → U4.SD (daisy-chained)
  ;; U4.SD → U1.GP10 (PIO SM0 input)
  ;; U1.GP27 → U3.L/R (low=left), U4.L/R (high=right)

  ;; SPI0 — SX1262 LoRa
  ;; U1.GP2  → U5.SCLK
  ;; U1.GP3  ← U5.MISO
  ;; U1.GP4  → U5.MOSI
  ;; U1.GP5  → U5.NSS (CS)
  ;; U5.DIO1 → U1.GP6 (interrupt)
  ;; U5.BUSY → U1.GP11
  ;; U1.GP7  → U5.NRST (reset)
  ;; U5.ANT  → J3.SIG (SMA → LoRa antenna)

  ;; SPI1 — microSD Card
  ;; U1.GP14 → J2.CLK
  ;; U1.GP15 ← J2.DO
  ;; U1.GP16 → J2.DI
  ;; U1.GP17 → J2.CS

  ;; UART0 — L86-Q GNSS
  ;; U1.GP0 (TX) → U6.RX
  ;; U1.GP1 (RX) ← U6.TX
  ;; U6.PPS  → U1.GP12
  ;; U1.GP20 → U6.FORCE_ON

  ;; USB — RP2040 native USB
  ;; U1.USB_DP ↔ J1.D+
  ;; U1.USB_DM ↔ J1.D-

  ;; QSPI Flash
  ;; U1.QSPI_SS → U2.CS
  ;; U1.QSPI_SCLK → U2.CLK
  ;; U1.QSPI_SD0 → U2.DI/IO0
  ;; U1.QSPI_SD1 ← U2.DO/IO1
  ;; U1.QSPI_SD2 ↔ U2.WP/IO2
  ;; U1.QSPI_SD3 ↔ U2.HOLD/IO3

  ;; Power chain:
  ;; J1.VBUS → U9.USB_IN (MCP73871)
  ;; Solar connector → U9.SOLAR_IN
  ;; U9.BAT → Battery+ → U10.VIN (RT9013)
  ;; U10.VOUT → VDD (3.3V rail)
  ;; All sensor VDD pins → VDD
  ;; All GND pins → GND plane
  ;; U9.PG → U1.GP23 (power good)
  ;; U9.STAT2 → U1.GP24 (charge status)

  ;; Battery/solar voltage sensing:
  ;; Battery+ → R5 (100k) → R6 (100k) → GND  (midpoint → U1.GP25 ADC)
  ;; Solar+ → R7 (100k) → R8 (100k) → GND  (midpoint → U1.GP26 ADC)

  ;; Status LED:
  ;; U1.GP13 (PIO SM1) → D1.DIN (WS2812B)

  ;; Crystal:
  ;; Y1 (12MHz) → U1.XIN, U1.XOUT (with 12pF load caps)

  ;; Decoupling: C1-C12 (100nF) one per IC VDD pin
  ;; Bulk: C13, C14 (10µF) on VDD rail
)