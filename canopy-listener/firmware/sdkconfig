# sdkconfig — Canopy Listener (RP2040)
# Optimized for low power + dual-core operation

# Clock configuration
CONFIG_CLOCK_FREQ=133000

# Sleep configuration
CONFIG_SLEEP_ENABLE=1

# I2C configuration
CONFIG_I2C0_SDA=18
CONFIG_I2C0_SCL=19
CONFIG_I2C0_FREQ=400000

# SPI0 configuration (LoRa)
CONFIG_SPI0_CLK=2
CONFIG_SPI0_MISO=3
CONFIG_SPI0_MOSI=4
CONFIG_SPI0_CS=5

# SPI1 configuration (SD card)
CONFIG_SPI1_CLK=14
CONFIG_SPI1_MISO=15
CONFIG_SPI1_MOSI=16
CONFIG_SPI1_CS=17

# UART0 configuration (GPS)
CONFIG_UART0_TX=0
CONFIG_UART0_RX=1
CONFIG_UART0_BAUD=9600

# ADC configuration
CONFIG_ADC_BATTERY_CH=25
CONFIG_ADC_SOLAR_CH=26