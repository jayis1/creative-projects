  ;; =============================================
  ;; Net connections (schematic wiring)
  ;; =============================================

  ;; I2C Bus — all sensors share SDA/SCL
  ;; U1.GPIO0 → U2.SDA, U3.SDA, U4.SDA, U5.SDA, U6.SDA
  ;; U1.GPIO1 → U2.SCL, U3.SCL, U4.SCL, U5.SCL, U6.SCL
  ;; R1 (4.7k) from VDD to SDA line
  ;; R2 (4.7k) from VDD to SCL line

  ;; Audio — MAX9814 output to ESP32 ADC
  ;; U7.OUT → U1.GPIO2 (ADC1_CH2)

  ;; Power chain:
  ;; J1.VBUS → U8.VDD (MCP73831)
  ;; U8.BAT → Battery+ → U9.VIN (AP2112)
  ;; U9.VOUT → VDD (3.3V rail)
  ;; All sensor VDD pins → VDD
  ;; All GND pins → GND plane

  ;; Control lines:
  ;; U1.GPIO6 → U4.RESET (SPS30)
  ;; U1.GPIO7 ← U4.INT (SPS30)
  ;; U1.GPIO8 ← U5.INT1 (IMU)
  ;; U1.GPIO14 ← U8.STAT (charge status)
  ;; U1.GPIO15 → D1.DIN (NeoPixel)
  ;; U1.GPIO20 ← U2.INT (BME680)
  ;; U1.GPIO12 ↔ J1.D+
  ;; U1.GPIO13 ↔ J1.D-

  ;; Decoupling: C1-C6 (100nF) one per IC VDD pin
)