// A simple JSON grammar
%start json

json   : value ;

value  : object
       | array
       | STRING
       | NUMBER
       | TRUE
       | FALSE
       | NULL
       ;

object : '{' '}'
       | '{' members '}'
       ;

members: pair
       | members ',' pair
       ;

pair   : STRING ':' value
       ;

array  : '[' ']'
       | '[' elements ']'
       ;

elements: value
        | elements ',' value
        ;